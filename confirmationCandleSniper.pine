// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Trading Assistant with 10 years experience
//
// 🎯 CONFIRMATION CANDLE SNIPER - Identify REAL vs FAKE Confirmations
// Works in conjunction with SR Fast indicator for precision entries
//
// 🔍 HOW TO USE:
// 1. Wait for diamond (◆) from SR indicator
// 2. Watch the Confirmation Score below candles
// 3. Score 3+ = REAL confirmation (green label)
// 4. Score <3 = FAKE confirmation (red label)
// 5. Enter on pullback after REAL confirmation
//
// 📊 SCORING SYSTEM:
// +1: Strong body (>60% of range)
// +1: Volume spike (>1.5x average)
// +1: Closes beyond S/R zone
// +1: No opposing wick
// +1: Engulfing pattern
// -1: Long wick (>40%)
// -1: Below average volume
// -1: Inside bar
// -1: Doji-like close
//
// 🎯 ENTRY SIGNALS:
// • "SNIPER ENTRY" = Perfect setup (score 4+)
// • "VALID" = Good setup (score 3)
// • "WAIT" = Needs more confirmation (score 1-2)
// • "FAKE" = Avoid entry (score ≤0)

//@version=5
indicator("Confirmation Candle Sniper [SR Companion]", shorttitle="Candle Sniper", overlay=true)

// ---------------------------------------------------------------------------------------------------------------------
// USER INPUTS
// ---------------------------------------------------------------------------------------------------------------------
// Visual Settings
bool showScore = input.bool(true, "Show Confirmation Score", group="Display")
bool showEntry = input.bool(true, "Show Entry Zones", group="Display")
bool showStrength = input.bool(true, "Show Candle Strength Meter", group="Display")
bool showPatterns = input.bool(true, "Show Candlestick Patterns", group="Display")

// Confirmation Settings
float bodyRatioMin = input.float(0.6, "Min Body Ratio for Strong Candle", minval=0.3, maxval=0.9, step=0.1, group="Confirmation Criteria")
float volumeMultiplier = input.float(1.5, "Volume Spike Multiplier", minval=1.0, maxval=3.0, step=0.1, group="Confirmation Criteria")
float wickRatioMax = input.float(0.4, "Max Wick Ratio for Weakness", minval=0.2, maxval=0.6, step=0.1, group="Confirmation Criteria")
int lookbackPeriod = input.int(20, "Lookback for Volume Average", minval=10, maxval=50, group="Confirmation Criteria")

// Entry Settings
bool showPullbackZone = input.bool(true, "Show 50% Pullback Entry", group="Entry Zones")
bool showAggressiveEntry = input.bool(false, "Show Aggressive Entry", group="Entry Zones")
bool showConservativeEntry = input.bool(true, "Show Conservative Entry (38.2%)", group="Entry Zones")

// Alert Settings
bool alertOnStrong = input.bool(true, "Alert on Strong Confirmation (3+)", group="Alerts")
bool alertOnPerfect = input.bool(true, "Alert on Perfect Setup (4+)", group="Alerts")

// ---------------------------------------------------------------------------------------------------------------------
// CALCULATIONS
// ---------------------------------------------------------------------------------------------------------------------

// Calculate candle metrics
candleRange = high - low
candleBody = math.abs(close - open)
bodyRatio = candleRange > 0 ? candleBody / candleRange : 0

// Upper and lower wicks
upperWick = high - math.max(close, open)
lowerWick = math.min(close, open) - low
upperWickRatio = candleRange > 0 ? upperWick / candleRange : 0
lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : 0

// Bullish or bearish
isBullish = close > open
isBearish = close < open

// Volume analysis
avgVolume = ta.sma(volume, lookbackPeriod)
volumeSpike = volume > (avgVolume * volumeMultiplier)
volumeRatio = avgVolume > 0 ? volume / avgVolume : 1

// Candlestick patterns
isEngulfing = (isBullish and isBearish[1] and close > high[1] and open < low[1]) or
              (isBearish and isBullish[1] and close < low[1] and open > high[1])

isDoji = bodyRatio < 0.1

isInsideBar = high < high[1] and low > low[1]

isHammer = isBullish and bodyRatio > 0.3 and lowerWickRatio > bodyRatio * 2 and upperWickRatio < 0.1
isShootingStar = isBearish and bodyRatio > 0.3 and upperWickRatio > bodyRatio * 2 and lowerWickRatio < 0.1

// Pin bar detection
isPinBar = (isBullish and lowerWickRatio > 0.66) or (isBearish and upperWickRatio > 0.66)

// ---------------------------------------------------------------------------------------------------------------------
// CONFIRMATION SCORING SYSTEM
// ---------------------------------------------------------------------------------------------------------------------

// Initialize score
var int confirmationScore = 0
score = 0

// POSITIVE POINTS
// Strong body
if bodyRatio > bodyRatioMin
    score := score + 1

// Volume spike
if volumeSpike
    score := score + 1

// Engulfing pattern
if isEngulfing
    score := score + 1

// Clean close (no opposing wick)
if isBullish and upperWickRatio < 0.1
    score := score + 1
else if isBearish and lowerWickRatio < 0.1
    score := score + 1

// Strong directional close
if isBullish and close > high[1]
    score := score + 1
else if isBearish and close < low[1]
    score := score + 1

// NEGATIVE POINTS
// Long wicks (shows rejection)
if upperWickRatio > wickRatioMax or lowerWickRatio > wickRatioMax
    score := score - 1

// Below average volume
if volume < avgVolume * 0.8
    score := score - 1

// Inside bar (indecision)
if isInsideBar
    score := score - 1

// Doji (extreme indecision)
if isDoji
    score := score - 2

// Store the score
confirmationScore := score

// ---------------------------------------------------------------------------------------------------------------------
// CANDLE STRENGTH CLASSIFICATION
// ---------------------------------------------------------------------------------------------------------------------

// Determine confirmation quality
confirmationQuality = score >= 4 ? "SNIPER" :
                     score == 3 ? "VALID" :
                     score >= 1 ? "WAIT" : "FAKE"

// Color coding
scoreColor = score >= 4 ? color.new(color.lime, 0) : score == 3 ? color.new(color.green, 0) : score >= 1 ? color.new(color.orange, 0) : color.new(color.red, 0)

bgColor = score >= 4 ? color.new(color.lime, 90) : score == 3 ? color.new(color.green, 90) : score >= 1 ? color.new(color.orange, 95) : color.new(color.red, 95)

// ---------------------------------------------------------------------------------------------------------------------
// ENTRY ZONES CALCULATION
// ---------------------------------------------------------------------------------------------------------------------

// Calculate entry levels for strong confirmations
float pullback50 = na
float pullback382 = na
float aggressiveEntry = na

if score >= 3 and not isDoji and not isInsideBar
    if isBullish
        pullback50 := low + (candleRange * 0.5)
        pullback382 := low + (candleRange * 0.382)
        aggressiveEntry := close
    else if isBearish
        pullback50 := high - (candleRange * 0.5)
        pullback382 := high - (candleRange * 0.618)
        aggressiveEntry := close

// ---------------------------------------------------------------------------------------------------------------------
// VISUALIZATION
// ---------------------------------------------------------------------------------------------------------------------

// Background color for current candle
bgcolor(showStrength ? bgColor : na, title="Confirmation Strength Background")

// Score labels
if showScore
    label.new(bar_index, low - (ta.atr(14) * 0.3),
              text="Score: " + str.tostring(score) + "\n" + confirmationQuality,
              color=scoreColor,
              style=label.style_label_up,
              textcolor=color.white,
              size=size.small)

// Candle patterns
if showPatterns
    if isEngulfing
        label.new(bar_index, high + (ta.atr(14) * 0.2),
                  text="ENGULF",
                  color=color.new(color.blue, 0),
                  style=label.style_label_down,
                  textcolor=color.white,
                  size=size.tiny)

    if isHammer
        label.new(bar_index, low - (ta.atr(14) * 0.5),
                  text="HAMMER",
                  color=color.new(color.green, 0),
                  style=label.style_label_up,
                  textcolor=color.white,
                  size=size.tiny)

    if isShootingStar
        label.new(bar_index, high + (ta.atr(14) * 0.5),
                  text="STAR",
                  color=color.new(color.red, 0),
                  style=label.style_label_down,
                  textcolor=color.white,
                  size=size.tiny)

    if isPinBar
        label.new(bar_index, isBullish ? low - (ta.atr(14) * 0.7) : high + (ta.atr(14) * 0.7),
                  text="PIN",
                  color=color.new(color.purple, 0),
                  style=isBullish ? label.style_label_up : label.style_label_down,
                  textcolor=color.white,
                  size=size.tiny)

// Entry zones for valid confirmations
if showEntry and score >= 3
    // 50% pullback entry
    if showPullbackZone and not na(pullback50)
        line.new(bar_index, pullback50, bar_index + 5, pullback50,
                 color=color.new(color.blue, 0),
                 style=line.style_dotted,
                 width=2)
        label.new(bar_index + 5, pullback50,
                  text="50% Entry",
                  color=color.new(color.blue, 0),
                  style=label.style_label_left,
                  textcolor=color.white,
                  size=size.tiny)

    // Conservative entry (38.2%)
    if showConservativeEntry and not na(pullback382)
        line.new(bar_index, pullback382, bar_index + 5, pullback382,
                 color=color.new(color.green, 0),
                 style=line.style_dotted,
                 width=1)
        label.new(bar_index + 5, pullback382,
                  text="38.2% Entry",
                  color=color.new(color.green, 0),
                  style=label.style_label_left,
                  textcolor=color.white,
                  size=size.tiny)

    // Aggressive entry
    if showAggressiveEntry and not na(aggressiveEntry)
        line.new(bar_index, aggressiveEntry, bar_index + 5, aggressiveEntry,
                 color=color.new(color.orange, 0),
                 style=line.style_dashed,
                 width=1)

// Volume indicator
plotshape(series=volumeSpike ? low - (ta.atr(14) * 0.1) : na,
          title="Volume Spike",
          style=shape.triangleup,
          location=location.absolute,
          color=color.new(color.yellow, 0),
          size=size.tiny)

// ---------------------------------------------------------------------------------------------------------------------
// TABLE: REAL-TIME CANDLE ANALYSIS
// ---------------------------------------------------------------------------------------------------------------------

// Define pattern text globally for use in alerts
patternText = isEngulfing ? "Engulfing" : isHammer ? "Hammer" : isShootingStar ? "Shooting Star" : isPinBar ? "Pin Bar" : isDoji ? "Doji" : isInsideBar ? "Inside Bar" : "None"

var table analysisTable = table.new(position.top_left, 2, 8)

if barstate.islast
    // Header
    table.cell(analysisTable, 0, 0, "Candle Analysis",
               text_color=color.white,
               bgcolor=color.new(color.blue, 30),
               text_size=size.small)
    table.cell(analysisTable, 1, 0, confirmationQuality,
               text_color=color.white,
               bgcolor=scoreColor,
               text_size=size.small)

    // Body Ratio
    table.cell(analysisTable, 0, 1, "Body Ratio",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 1, str.tostring(bodyRatio, "#.##") + (bodyRatio > bodyRatioMin ? " ✓" : " ✗"),
               text_color=bodyRatio > bodyRatioMin ? color.green : color.red,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Volume
    table.cell(analysisTable, 0, 2, "Volume",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 2, str.tostring(volumeRatio, "#.#") + "x" + (volumeSpike ? " ✓" : " ✗"),
               text_color=volumeSpike ? color.green : color.red,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Pattern
    table.cell(analysisTable, 0, 3, "Pattern",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 3, patternText,
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Score
    table.cell(analysisTable, 0, 4, "Score",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 4, str.tostring(score) + "/5",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Entry Suggestion
    entryText = score >= 4 ? "ENTER NOW!" : score == 3 ? "Wait Pullback" : score >= 1 ? "Need More" : "SKIP"

    table.cell(analysisTable, 0, 5, "Action",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 5, entryText,
               text_color=score >= 3 ? color.lime : color.red,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Timeframe
    table.cell(analysisTable, 0, 6, "Timeframe",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 6, timeframe.period,
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

    // Direction
    directionText = isBullish ? "↑ BULLISH" : isBearish ? "↓ BEARISH" : "→ NEUTRAL"
    directionColor = isBullish ? color.green : isBearish ? color.red : color.gray

    table.cell(analysisTable, 0, 7, "Direction",
               text_color=color.white,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)
    table.cell(analysisTable, 1, 7, directionText,
               text_color=directionColor,
               bgcolor=color.new(color.black, 70),
               text_size=size.tiny)

// ---------------------------------------------------------------------------------------------------------------------
// ALERTS
// ---------------------------------------------------------------------------------------------------------------------

// Strong confirmation alert (score 3)
if alertOnStrong and score == 3
    alert("🎯 VALID Confirmation Candle!\n" +
          "Score: 3/5\n" +
          "Pattern: " + patternText + "\n" +
          "Volume: " + str.tostring(volumeRatio, "#.#") + "x average\n" +
          "Action: Wait for pullback to " + (isBullish ? "support" : "resistance"),
          alert.freq_once_per_bar)

// Perfect setup alert (score 4+)
if alertOnPerfect and score >= 4
    alert("🔥 SNIPER ENTRY Signal!\n" +
          "Score: " + str.tostring(score) + "/5 - PERFECT!\n" +
          "Pattern: " + patternText + "\n" +
          "Volume: " + str.tostring(volumeRatio, "#.#") + "x average\n" +
          "Action: ENTER NOW or at 50% pullback\n" +
          "This is a HIGH PROBABILITY setup!",
          alert.freq_once_per_bar)

// Fake signal warning
alertcondition(score <= 0,
               title="⚠️ FAKE Confirmation Warning",
               message="FAKE confirmation detected!\nScore: {{plot_0}}\nDO NOT ENTER - Wait for better setup")

// Engulfing pattern alert
alertcondition(isEngulfing and score >= 3,
               title="🎯 Engulfing + Confirmation",
               message="Engulfing pattern with strong confirmation!\nScore: {{plot_0}}\nHIGH PROBABILITY trade setup")

// ---------------------------------------------------------------------------------------------------------------------
// PLOTS FOR ALERTCONDITION
// ---------------------------------------------------------------------------------------------------------------------
plot(score, title="Confirmation Score", display=display.none)
plot(volumeRatio, title="Volume Ratio", display=display.none)
plot(bodyRatio * 100, title="Body Ratio %", display=display.none)