// © ChartPrime
// Modified for Scalping (M1/M5/M15) - Optimized for XAU & Forex
//
// ⚠️ CRITICAL MULTI-TIMEFRAME RULES (MUST READ):
// ==================================================
// 🎯 THE GOLDEN RULE: "M15 DECIDES, M5 EXECUTES"
//
// ❌ NEVER trade M5 diamonds alone - 70% are FAKE!
// ✅ ALWAYS check M15 first - this is where institutions operate
//
// 📊 PROPER TRADING WORKFLOW:
// 1. START on M15 → Find diamond at S/R (this is your BIAS)
// 2. SWITCH to M5 → Wait for retest of M15 level (this is your ENTRY)
// 3. EXECUTE on M5 → Enter on rejection candle with tight stop
//
// 🔍 WHY THIS WORKS:
// • M15 diamonds = Institutional levels (banks, funds)
// • M5 diamonds alone = Retail noise (stop hunts, fakeouts)
// • M15 structure + M5 entry = Professional edge
//
// ⏰ TIMING RULES:
// • Best entries: Within 30-45 min of M15 diamond
// • After 1 hour: Level often exhausted, skip
// • First retest: Highest win rate
// • Third retest: Usually breaks
//
// 📊 TRADING STRATEGIES:
// 1. FIRST TOUCH: Price touches S/R → diamond (◆) appears → rejection candle → ENTER
// 2. BREAK & RETEST: See "SBR/RBS ⚠" label → wait for pullback → diamond (◆) at retest → ENTER
//    - RBS: Resistance broken → becomes support → BUY on retest (green ◆ below)
//    - SBR: Support broken → becomes resistance → SELL on retest (red ◆ above)
// 3. CONFLUENCE: Best entries when diamond + candlestick pattern + volume confirmation align
//
// 💎 ENTRY SIGNALS:
// - Green ◆ below candle = BUY signal (support holds or broken resistance retested)
// - Red ◆ above candle = SELL signal (resistance holds or broken support retested)
//
// 🟠 ZONE FLIP (SBR/RBS):
// - Orange zone with "SBR ⚠" = Support Became Resistance (zone flipped - be careful!)
// - Orange zone with "RBS ⚠" = Resistance Became Support (zone flipped - wait for retest)
//
// 📈 SIMPLE EXECUTION CHECKLIST:
// ☐ M15 diamond appeared? (Your reason to trade)
// ☐ Price returned to level on M5? (Your entry zone)
// ☐ Rejection candle formed? (Your trigger)
// ☐ Risk:Reward > 1:2? (Your edge)
// If all ✓ → EXECUTE. If any ✗ → SKIP.
//
// 📏 RISK MANAGEMENT:
// - Stop Loss: Beyond box edge + 5-10 pip buffer
// - Take Profit: Next S/R zone OR minimum 1:2 RR
// - Avoid trading during major news events (NFP, FOMC, CPI)

//@version=5
indicator("SR Fast - AGGRESSIVE Scalping 7,2,1 [Custom]", shorttitle = "SR Fast 7,2,1", overlay=true, max_boxes_count = 50)


// ---------------------------------------------------------------------------------------------------------------------}
// 𝙐𝙎𝙀𝙍 𝙄𝙉𝙋𝙐𝙏𝙎
// ---------------------------------------------------------------------------------------------------------------------{

// AUTO TIMEFRAME DETECTION
bool autoSettings = input.bool(true, "🔄 Auto-Adjust Settings by Timeframe", group = "Settings",
      tooltip = "✅ AUTO MODE (Aggressive Scalping)\n\n📊 Automatic settings per timeframe:\n• M1: 5,2,0.6 (Ultra-fast scalping)\n• M5: 7,2,1.0 (Fast scalping - YOUR SWEET SPOT)\n• M15: 8,2,1.0 (Quick trades)\n• M30: 10,3,1.2 (Balanced)\n• H1+: 15,4,1.5 (Position)\n\n🟨 Gold/XAU: +20% wider zones\n\nToggle OFF for manual control")

// Get current timeframe and set optimal defaults
getOptimalSettings() =>
    tf = timeframe.period
    // M1 Settings (Ultra-fast scalping - AGGRESSIVE)
    if tf == "1"
        [5, 2, 0.6]
    // M5 Settings (Fast scalping - YOUR PREFERRED SETTINGS)
    else if tf == "5"
        [8, 2, 1.0]
    // M15 Settings (Quick trades - SCALPER OPTIMIZED)
    else if tf == "15"
        [10, 2, 1.0]
    // M30 Settings (Balanced)
    else if tf == "30"
        [12, 3, 1.2]
    // H1 and higher (Position trading)
    else if timeframe.isintraday == false or timeframe.isdaily
        [15, 4, 1.5]
    // Default (other timeframes)
    else
        [7, 2, 1.0]

[defaultLookback, defaultVolLen, defaultBoxWidth] = getOptimalSettings()

// Manual override settings (only used when autoSettings is false)
int   manualLookback = input.int(7, "Manual Lookback Period", minval=1, group = "Manual Settings",
      tooltip="SCALPER SETTINGS: M1: 5 | M5: 7 | M15: 8 | M30: 10 | H1+: 15")
int   manualVolLen   = input.int(2, "Manual Volume Filter", minval=1, group = "Manual Settings",
      tooltip = "Keep at 2 for all scalping timeframes (M1-M15)")
float manualBoxWidth = input.float(1.0, "Manual Box Width", maxval = 10, minval = 0.1, step = 0.1,
      tooltip="M1: 0.6 | M5: 1.0 | M15: 1.0 | M30: 1.2 | H1+: 1.5", group = "Manual Settings")

// Final settings (either auto or manual based on user choice)
int   lookbackPeriod = autoSettings ? defaultLookback : manualLookback
int   vol_len        = autoSettings ? defaultVolLen : manualVolLen
float box_withd      = autoSettings ? defaultBoxWidth : manualBoxWidth

// Asset-specific adjustments (Gold/XAU needs wider zones)
bool isGold = str.contains(syminfo.ticker, "XAU") or str.contains(syminfo.ticker, "GOLD")
float assetMultiplier = isGold ? 1.2 : 1.0
box_withd := box_withd * assetMultiplier

// ---------------------------------------------------------------------------------------------------------------------}
// 𝙀𝙈𝘼𝟮𝟬𝟬 𝘽𝙄𝘼𝙎 𝙁𝙄𝙇𝙏𝙀𝙍
// ---------------------------------------------------------------------------------------------------------------------{
// EMA200 = filter ARAH/bias trend besar. S/R & Volume Profile kasih LEVEL (di mana),
// EMA200 kasih ARAH (ke mana). Aturannya: BUY hanya saat harga di ATAS EMA200 (bias
// naik), SELL hanya saat di BAWAH (bias turun). Searah prinsip "M15 DECIDES".
string grpEma      = "🧭 EMA200 Bias Filter"
bool   showEma     = input.bool(true, "Show EMA200 Line", group = grpEma)
bool   useEmaFilter = input.bool(true, "Filter Signals by EMA200 Bias", group = grpEma, tooltip = "✅ ON: sinyal BUY (◆ hijau) hanya muncul saat harga DI ATAS EMA200; sinyal SELL (◆ merah) hanya saat DI BAWAH.\n❌ OFF: tampilkan semua sinyal seperti semula (tanpa filter). Matikan saat market jelas ranging.")
int    emaLen      = input.int(200, "EMA Length", minval = 1, group = grpEma)
string emaBiasTF   = input.timeframe("", "Bias Timeframe (kosong = TF chart)", group = grpEma, tooltip = "Kosongkan = EMA200 di TF chart (smooth, tanpa lag).\nIsi '15' agar SELALU pakai bias M15 walau chart di M1/M5 (sesuai aturan 'M15 DECIDES, M5 EXECUTES').\nMode HTF ini NON-REPAINT: pakai bar HTF yang sudah close, jadi angka final & tidak berubah intrabar. Tradeoff: bias telat maks 1 bar HTF, dan garis tampak bertangga di TF kecil.")
color  emaColor    = input.color(color.new(color.blue, 0), "EMA Color", group = grpEma)

// Non-repaint HTF: ambil nilai EMA200 dari bar HTF yang SUDAH CLOSE ([1] + lookahead_on).
// Angka yang tampil = angka final, tidak berubah intrabar. Tradeoff: bias telat maks 1 bar HTF.
string effTF   = emaBiasTF == "" ? timeframe.period : emaBiasTF
float  emaHTF  = request.security(syminfo.tickerid, effTF, ta.ema(close, emaLen)[1], lookahead = barmerge.lookahead_on)
float  ema200  = emaBiasTF == "" ? ta.ema(close, emaLen) : emaHTF
plot(showEma ? ema200 : na, "EMA200 Bias", color = emaColor, linewidth = 2)

// Bias arah — dipakai untuk filter sinyal di bagian bawah.
// Saat filter OFF, kedua bias = true → sinyal identik dengan versi tanpa filter.
bool bullBias = not useEmaFilter or close > ema200
bool bearBias = not useEmaFilter or close < ema200

// Display current settings info
var table infoTable = table.new(position.top_right, 2, 5)
if barstate.islast
    currentTF = timeframe.period
    modeText = autoSettings ? "🔄 AUTO" : "🔧 MANUAL"
    assetText = isGold ? "🟨 GOLD" : "💱 " + syminfo.ticker

    // TF role in workflow: M15 = BIAS, M5 = TREND, M1 = ENTRY
    warningText = currentTF == "15" ? "① BIAS TF" : currentTF == "5" ? "② TREND TF" : currentTF == "1" ? "③ ENTRY TF" : "TF: " + currentTF
    warningColor = currentTF == "15" ? color.new(color.green, 30) : currentTF == "5" ? color.new(color.blue, 30) : currentTF == "1" ? color.new(color.purple, 30) : color.new(color.gray, 70)

    // Header
    table.cell(infoTable, 0, 0, modeText, text_color=color.white, bgcolor=color.new(color.blue, 70), text_size=size.small)
    table.cell(infoTable, 1, 0, warningText, text_color=color.white, bgcolor=warningColor, text_size=size.small)

    // Settings display
    table.cell(infoTable, 0, 1, "Lookback: " + str.tostring(lookbackPeriod), text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.tiny)
    table.cell(infoTable, 1, 1, "Vol Filter: " + str.tostring(vol_len), text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.tiny)

    // Box width and asset
    table.cell(infoTable, 0, 2, "Box: " + str.tostring(box_withd, "#.#"), text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.tiny)
    table.cell(infoTable, 1, 2, assetText, text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.tiny)

    // Trading rule reminder (M15 bias → M5 trend → M1 execution)
    ruleText = currentTF == "15" ? "FIND BIAS" : currentTF == "5" ? "CONFIRM TREND" : currentTF == "1" ? "EXECUTE HERE" : ""
    emojiText = currentTF == "15" ? "🧭" : currentTF == "5" ? "📈" : currentTF == "1" ? "🎯" : ""
    if ruleText != ""
        table.cell(infoTable, 0, 3, ruleText, text_color=color.white, bgcolor=color.new(color.purple, 70), text_size=size.tiny)
        table.cell(infoTable, 1, 3, emojiText, text_color=color.white, bgcolor=color.new(color.purple, 70), text_size=size.tiny)

    // EMA200 bias row
    biasText  = not useEmaFilter ? "OFF" : close > ema200 ? "▲ BULLISH" : "▼ BEARISH"
    biasColor = not useEmaFilter ? color.new(color.gray, 50) : close > ema200 ? color.new(color.green, 30) : color.new(color.red, 30)
    table.cell(infoTable, 0, 4, "EMA200", text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.tiny)
    table.cell(infoTable, 1, 4, biasText, text_color=color.white, bgcolor=biasColor, text_size=size.tiny)


// ---------------------------------------------------------------------------------------------------------------------}
// 𝙄𝙉𝘿𝙄𝘾𝘼𝙏𝙊𝙍 𝘾𝘼𝙇𝘾𝙐𝙇𝘼𝙏𝙄𝙊𝙉𝙎
// ---------------------------------------------------------------------------------------------------------------------{
// Delta Volume Function
upAndDownVolume() =>
    posVol = 0.0
    negVol = 0.0
    
    var isBuyVolume = true    

    switch
        close > open   => isBuyVolume := true
        close < open   => isBuyVolume := false

    if isBuyVolume
        posVol += volume
    else
        negVol -= volume

    posVol + negVol


// Function to identify support and resistance boxes
calcSupportResistance(src, lookbackPeriod) =>
    // Volume
    Vol    = upAndDownVolume()
    vol_hi = ta.highest(Vol/2.5, vol_len)
    vol_lo = ta.lowest(Vol/2.5, vol_len)

    var float supportLevel      = na
    var float supportLevel_1    = na    
    var float resistanceLevel   = na
    var float resistanceLevel_1 = na    
    var box   sup               = na
    var box   res               = na
    var color res_color         = na
    var color sup_color         = na    
    var float multi             = na

    var bool  brekout_res       = na
    var bool  brekout_sup       = na
    var bool  res_holds         = na
    var bool  sup_holds         = na

    // Find pivot points
    pivotHigh = ta.pivothigh(src, lookbackPeriod, lookbackPeriod)
    pivotLow  = ta.pivotlow (src, lookbackPeriod, lookbackPeriod)
    // Box width
    atr       = ta.atr(200)
    withd     = atr * box_withd

    // Find support levels with Positive Volume
    if (not na(pivotLow)) and Vol > vol_hi 

        supportLevel   := pivotLow
        supportLevel_1 := supportLevel-withd       

        topLeft         = chart.point.from_index(bar_index-lookbackPeriod, supportLevel)
        bottomRight     = chart.point.from_index(bar_index, supportLevel_1)

        sup_color      := color.from_gradient(Vol, 0, ta.highest(Vol, 25), color(na), color.new(color.green, 30))

        sup := box.new(
                       top_left     = topLeft, 
                       bottom_right = bottomRight, 
                       border_color = color.green, 
                       border_width = 1, 
                       bgcolor      = sup_color, 
                       text         = "Vol: "+str.tostring(math.round(Vol,2)), 
                       text_color   = chart.fg_color, 
                       text_size    = size.small
                       ) 


    // Find resistance levels with Negative Volume
    if (not na(pivotHigh)) and Vol < vol_lo
   
        resistanceLevel   := pivotHigh
        resistanceLevel_1 := resistanceLevel+withd

        topLeft            = chart.point.from_index(bar_index-lookbackPeriod, resistanceLevel)
        bottomRight        = chart.point.from_index(bar_index, resistanceLevel_1)

        res_color         := color.from_gradient(Vol, ta.lowest(Vol, 25), 0, color.new(color.red, 30), color(na))

        res := box.new(
                       top_left     = topLeft, 
                       bottom_right = bottomRight, 
                       border_color = color.red, 
                       border_width = 1, 
                       bgcolor      = res_color, 
                       text         = "Vol: "+str.tostring(math.round(Vol,2)), 
                       text_color   = chart.fg_color, 
                       text_size    = size.small
                       ) 

    // Adaptive Box Len
    sup.set_right(bar_index+1)
    res.set_right(bar_index+1)

    // Break of support or resistance conditions
    brekout_res := ta.crossover(low, resistanceLevel_1)
    res_holds   := ta.crossunder(high, resistanceLevel)

    sup_holds   := ta.crossover(low, supportLevel)
    brekout_sup := ta.crossunder(high, supportLevel_1)

    // Change Color of Support to ORANGE if it was break (SBR - Support Became Resistance)
    if brekout_sup
        sup.set_bgcolor(color.new(color.orange, 80))
        sup.set_border_color(color.orange)
        sup.set_border_style(line.style_dashed)

    if sup_holds
        sup.set_bgcolor(sup_color)
        sup.set_border_color(color.green)
        sup.set_border_style(line.style_solid)

    // Change color of resistance to ORANGE if it was break (RBS - Resistance Became Support)
    if brekout_res
        res.set_bgcolor(color.new(color.orange, 80))
        res.set_border_color(color.orange)
        res.set_border_style(line.style_dashed)

    if res_holds
        res.set_bgcolor(res_color)
        res.set_border_color(color.new(color.red, 0))
        res.set_border_style(line.style_solid)

    [supportLevel, resistanceLevel, brekout_res, res_holds, sup_holds, brekout_sup]


// Calculate support and resistance levels and their breakouts
[supportLevel,
         resistanceLevel, 
             brekout_res, 
                 res_holds, 
                     sup_holds, 
                         brekout_sup] = calcSupportResistance(close, lookbackPeriod)


// Check if Resistance become Support or Support Become Resistance
var bool res_is_sup = na
var bool sup_is_res = na

switch
    brekout_res => res_is_sup := true
    res_holds   => res_is_sup := false

switch
    brekout_sup => sup_is_res := true
    sup_holds   => sup_is_res := false


// ---------------------------------------------------------------------------------------------------------------------}
// 𝙑𝙄𝙎𝙐𝘼𝙇𝙄𝙕𝘼𝙏𝙄𝙊𝙉
// ---------------------------------------------------------------------------------------------------------------------{
// Filter sinyal dengan bias EMA200:
//   BUY (support hold / RBS retest)  hanya tampil saat bullBias (harga di atas EMA200)
//   SELL (resistance hold / SBR retest) hanya tampil saat bearBias (harga di bawah EMA200)
// Saat useEmaFilter = OFF, bullBias/bearBias = true → sinyal sama persis versi lama.
bool sig_res_holds = res_holds and bearBias
bool sig_sup_holds = sup_holds and bullBias
bool sig_rbs_buy   = res_is_sup and ta.crossover(low, resistanceLevel)  and bullBias
bool sig_sbr_sell  = sup_is_res and ta.crossunder(high, supportLevel)   and bearBias

// Plot Res and Sup breakouts and holds
plotchar(sig_res_holds, "Resistance Holds", "◆", color=#e92929, size=size.tiny, location=location.abovebar, offset=-1)
plotchar(sig_sup_holds, "Support Holds", "◆", color=#20ca26, size=size.tiny, location=location.belowbar, offset=-1)

// RETEST SIGNALS - Diamond appears when price retests broken level
// RBS: Resistance broken (became support) → price pulls back → bounces from old resistance (now support)
plotchar(sig_rbs_buy, "RBS Retest - BUY", "◆", color=#20ca26, size=size.tiny, location=location.belowbar, offset=-1)

// SBR: Support broken (became resistance) → price pulls back → rejected from old support (now resistance)
plotchar(sig_sbr_sell, "SBR Retest - SELL", "◆", color=#e92929, size=size.tiny, location=location.abovebar, offset=-1)

// Break Out Labels (SBR/RBS with Orange)
if brekout_sup and not sup_is_res[1]
    label.new(bar_index[1], supportLevel[1], text="SBR ⚠", style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small, tooltip="Support Became Resistance")

if brekout_res and not res_is_sup[1]
    label.new(bar_index[1], resistanceLevel[1], text="RBS ⚠", style=label.style_label_up, color=color.orange, textcolor=color.white, size=size.small, tooltip="Resistance Became Support")

// ---------------------------------------------------------------------------------------------------------------------}
// 𝘼𝙇𝙀𝙍𝙏𝙎 & 𝙏𝙍𝘼𝘿𝙄𝙉𝙂 𝙎𝙄𝙂𝙉𝘼𝙇𝙎
// ---------------------------------------------------------------------------------------------------------------------{

// Get current timeframe for alert messages
tf_text = timeframe.period

// BREAK & RETEST ALERTS (Most important for scalping)
alertcondition(sig_rbs_buy, title="🟢 RBS RETEST - BUY", message="🎯 [{{ticker}}] {{interval}} | RBS RETEST BUY\n💹 Entry: {{close}}\n⏰ Time: {{time}}\n📊 Old Resistance → Now Support\n🧭 Searah bias EMA200\n✅ HIGH PROBABILITY SETUP")

alertcondition(sig_sbr_sell, title="🔴 SBR RETEST - SELL",message="🎯 [{{ticker}}] {{interval}} | SBR RETEST SELL\n📉 Entry: {{close}}\n⏰ Time: {{time}}\n📊 Old Support → Now Resistance\n🧭 Searah bias EMA200\n✅ HIGH PROBABILITY SETUP")

// First Touch Alerts
alertcondition(sig_res_holds, title="🔴 Resistance Touch", message="⚠️ [{{ticker}}] {{interval}} | RESISTANCE TOUCH\n📉 Level: {{close}}\n⏰ Time: {{time}}\n📊 Watch for rejection candle\n⚡ Quick scalp opportunity")

alertcondition(sig_sup_holds, title="🟢 Support Touch", message="⚠️ [{{ticker}}] {{interval}} | SUPPORT TOUCH\n💹 Level: {{close}}\n⏰ Time: {{time}}\n📊 Watch for bounce candle\n⚡ Quick scalp opportunity")

// Breakout Alerts (Wait for retest!)
alertcondition(brekout_res, title="⬆️ Resistance Break", message="🚨 [{{ticker}}] {{interval}} | RESISTANCE BROKEN\n📈 Price: {{close}}\n⏰ Time: {{time}}\n⏳ WAIT for pullback & retest\n🎯 Potential RBS setup coming")

alertcondition(brekout_sup, title="⬇️ Support Break", message="🚨 [{{ticker}}] {{interval}} | SUPPORT BROKEN\n📉 Price: {{close}}\n⏰ Time: {{time}}\n⏳ WAIT for pullback & retest\n🎯 Potential SBR setup coming")

// ◆
// ---------------------------------------------------------------------------------------------------------------------}
