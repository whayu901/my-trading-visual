//@version=5
indicator("Trend Detector - S/R Compatible", overlay=true)

// ============================================================
// 📊 TREND DETECTOR - Optimized for S/R Trading
// ============================================================
// Works best when combined with Support & Resistance indicator
// Provides trend direction and strength confirmation
// ============================================================

/// === INPUTS ===
emaFastLen = input.int(9, title="Fast EMA", minval=5, maxval=20, group="EMA Settings")
emaSlowLen = input.int(21, title="Slow EMA", minval=10, maxval=50, group="EMA Settings")
emaTrendLen = input.int(50, title="Trend EMA (Filter)", minval=20, maxval=200, group="EMA Settings")

rsiPeriod = input.int(14, title="RSI Period", group="RSI Settings")
rsiOB = input.int(70, title="RSI Overbought", group="RSI Settings")
rsiOS = input.int(30, title="RSI Oversold", group="RSI Settings")

showCloud = input.bool(true, title="Show EMA Cloud", group="Display")
showTrendBG = input.bool(true, title="Show Trend Background", group="Display")
showSignals = input.bool(true, title="Show BUY/SELL Labels", group="Display")

/// === TREND DETECTION ===
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)  // Main trend filter
rsi = ta.rsi(close, rsiPeriod)

// Trend Direction
trendUp = emaFast > emaSlow and close > emaTrend
trendDown = emaFast < emaSlow and close < emaTrend
trendNeutral = not trendUp and not trendDown

// Crossover Signals (with RSI filter)
bullishCross = ta.crossover(emaFast, emaSlow) and rsi < rsiOB and close > emaTrend
bearishCross = ta.crossunder(emaFast, emaSlow) and rsi > rsiOS and close < emaTrend

/// === TREND STRENGTH ===
// Distance between EMAs (normalized by ATR for comparison)
atr = ta.atr(14)
emaDistance = math.abs(emaFast - emaSlow)
trendStrength = emaDistance / atr

// Classify trend strength
strongTrend = trendStrength > 0.5
moderateTrend = trendStrength > 0.2 and trendStrength <= 0.5
weakTrend = trendStrength <= 0.2

/// === SIGNAL MARKERS ===
buySignal = bullishCross and showSignals
sellSignal = bearishCross and showSignals

// Plot signals with trend strength indicator
plotshape(buySignal and strongTrend, location=location.belowbar, style=shape.labelup, text="BUY\n⚡", color=color.new(color.green, 0), textcolor=color.white, size=size.normal, title="Strong BUY")
plotshape(buySignal and moderateTrend, location=location.belowbar, style=shape.labelup, text="BUY", color=color.new(color.green, 30), textcolor=color.white, size=size.small, title="Moderate BUY")

plotshape(sellSignal and strongTrend, location=location.abovebar, style=shape.labeldown, text="SELL\n⚡", color=color.new(color.red, 0), textcolor=color.white, size=size.normal, title="Strong SELL")
plotshape(sellSignal and moderateTrend, location=location.abovebar, style=shape.labeldown, text="SELL", color=color.new(color.red, 30), textcolor=color.white, size=size.small, title="Moderate SELL")

/// === EMA PLOTS ===
p1 = plot(emaFast, title="EMA 9", color=color.new(color.blue, 0), linewidth=2)
p2 = plot(emaSlow, title="EMA 21", color=color.new(color.orange, 0), linewidth=2)
plot(emaTrend, title="EMA 50 (Trend)", color=color.new(color.gray, 30), linewidth=2)

/// === EMA CLOUD ===
bullColor = color.new(color.green, 90)
bearColor = color.new(color.red, 90)
cloudColor = emaFast > emaSlow ? bullColor : bearColor
fill(p1, p2, color=showCloud ? cloudColor : na, title="EMA Cloud")

/// === TREND BACKGROUND ===
bgColor = trendUp ? color.new(color.green, 97) : trendDown ? color.new(color.red, 97) : na
bgcolor(showTrendBG ? bgColor : na, title="Trend Background")

/// === TREND INFO TABLE ===
if barstate.islast
    var table infoTable = table.new(position.bottom_right, 2, 5, border_width=1)

    // Clear table untuk responsive zoom
    table.clear(infoTable, 0, 0, 1, 4)

    table.cell(infoTable, 0, 0, "📈 Trend Info", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.normal)
    table.merge_cells(infoTable, 0, 0, 1, 0)

    // Current trend
    trendText = trendUp ? "UPTREND ↗" : trendDown ? "DOWNTREND ↘" : "SIDEWAYS ↔"
    trendColor = trendUp ? color.new(color.green, 50) : trendDown ? color.new(color.red, 50) : color.new(color.gray, 50)
    table.cell(infoTable, 0, 1, "Current Trend", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(infoTable, 1, 1, trendText, text_color=color.white, bgcolor=trendColor)

    // Trend strength
    strengthText = strongTrend ? "Strong" : moderateTrend ? "Moderate" : "Weak"
    strengthColor = strongTrend ? color.new(color.green, 50) : moderateTrend ? color.new(color.orange, 50) : color.new(color.gray, 50)
    table.cell(infoTable, 0, 2, "Strength", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(infoTable, 1, 2, strengthText, text_color=color.white, bgcolor=strengthColor)

    // RSI value
    rsiText = str.tostring(math.round(rsi, 2))
    rsiColor = rsi > rsiOB ? color.new(color.red, 50) : rsi < rsiOS ? color.new(color.green, 50) : color.new(color.gray, 50)
    table.cell(infoTable, 0, 3, "RSI", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(infoTable, 1, 3, rsiText, text_color=color.white, bgcolor=rsiColor)

    // Trading bias
    biasText = trendUp and strongTrend ? "BUY on S/R ✓" : trendDown and strongTrend ? "SELL on S/R ✓" : "Wait for Signal"
    biasColor = trendUp and strongTrend ? color.new(color.green, 0) : trendDown and strongTrend ? color.new(color.red, 0) : color.new(color.orange, 50)
    table.cell(infoTable, 0, 4, "Trading Bias", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(infoTable, 1, 4, biasText, text_color=color.white, bgcolor=biasColor)

/// === ALERTS ===
alertcondition(buySignal and strongTrend, title="Strong BUY Signal", message="Strong UPTREND + BUY Signal on {{ticker}} - Look for S/R Buy Setup!")
alertcondition(sellSignal and strongTrend, title="Strong SELL Signal", message="Strong DOWNTREND + SELL Signal on {{ticker}} - Look for S/R Sell Setup!")
alertcondition(buySignal, title="BUY Signal", message="Bullish crossover on {{ticker}}")
alertcondition(sellSignal, title="SELL Signal", message="Bearish crossover on {{ticker}}")

// ============================================================
// 💡 HOW TO USE WITH S/R INDICATOR:
// ============================================================
// 1. Use this indicator to identify TREND DIRECTION
// 2. Use S/R indicator to identify ENTRY ZONES
// 3. Only take S/R trades that align with trend:
//    - UPTREND (green bg) → Only take BUY signals from S/R
//    - DOWNTREND (red bg) → Only take SELL signals from S/R
//    - SIDEWAYS → Trade both directions carefully
// 4. Strong trend + S/R zone = BEST setup
// ============================================================
